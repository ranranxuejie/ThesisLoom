from typing import Dict, Any
import os, json
import re
from datetime import datetime


def resolve_inputs_path() -> str:
    candidate_paths = [
        "inputs/inputs_safe.json",
        "inputs_safe.json",
        "inputs.json",
        "inputs/inputs.json",
    ]
    for path in candidate_paths:
        if os.path.exists(path):
            return path
    return "inputs/inputs.json"


def read_text_if_exists(path: str) -> str:
    if not os.path.exists(path):
        return ""
    with open(path, "r", encoding="utf-8") as f:
        return f.read().strip()


def build_output_paths(model: str, topic: str, prompt_language: str) -> tuple[str, str]:
    safe_model = ''.join(ch for ch in str(model) if ch not in '\\/*?:"<>|').replace(" ", "_")
    base_topic = topic if str(topic).strip() else "auto_title_pending"
    safe_topic = ''.join(ch for ch in base_topic if ch not in '\\/*?:"<>|').replace(" ", "_")
    output = f"completed_history/{safe_model}_{safe_topic}_{prompt_language}.md"
    checkpoint = f"completed_history/{safe_model}_{safe_topic}_{prompt_language}_checkpoint.json"
    return output, checkpoint


def _safe_int_token(value: str) -> int:
    try:
        return int(value)
    except Exception:
        return 10**9


def _parse_sub_chapter_id(sub_id: str) -> tuple[int, int]:
    text = str(sub_id or "").strip()
    if not text:
        return 10**9, 10**9

    m = re.match(r"^(\d+)\.(\d+)$", text)
    if m:
        return _safe_int_token(m.group(1)), _safe_int_token(m.group(2))

    m = re.match(r"^(\d+)$", text)
    if m:
        return _safe_int_token(m.group(1)), 0

    return 10**9, 10**9


def _build_layout_rank_map(state: "PaperWriterState") -> Dict[str, int]:
    rank_map: Dict[str, int] = {}
    outline = getattr(state, "outline", [])
    if not isinstance(outline, list):
        return rank_map

    majors = []
    for idx, major in enumerate(outline):
        major_id = str((major or {}).get("major_chapter_id", "")).strip()
        major_key = _safe_int_token(major_id) if major_id else 10**9
        majors.append((major_key, idx, major or {}))
    majors.sort(key=lambda x: (x[0], x[1]))

    cursor = 0
    for _, _, major in majors:
        for sub in (major.get("sub_sections", []) or []):
            sub_id = str((sub or {}).get("sub_chapter_id", "")).strip()
            if sub_id and sub_id not in rank_map:
                rank_map[sub_id] = cursor
                cursor += 1
    return rank_map


def _section_sort_key(section: Dict[str, Any], rank_map: Dict[str, int]) -> tuple[int, int, int, int]:
    sub_id = str(section.get("sub_chapter_id", "")).strip()
    major_no, sub_no = _parse_sub_chapter_id(sub_id)
    layout_rank = rank_map.get(sub_id, 10**9)
    actual_order = int(section.get("actual_order_index", 10**9) or 10**9)
    return layout_rank, major_no, sub_no, actual_order


def _sanitize_markdown_sse_artifacts(text: str) -> str:
    raw = str(text or "")
    if not raw:
        return ""

    cleaned = re.sub(r"(?im)^\s*data:\s*\[done\]\s*$", "", raw)
    cleaned = re.sub(
        r"(?im)^\s*data:\s*\{.*\"object\"\s*:\s*\"chat\.completion\.chunk\".*\}\s*$",
        "",
        cleaned,
    )
    cleaned = re.sub(r"\n{3,}", "\n\n", cleaned)
    return cleaned.strip()


def save_markdown_snapshot(state: "PaperWriterState", output_path: str) -> None:
    rank_map = _build_layout_rank_map(state)
    completed_thesis = sorted(state.completed_sections, key=lambda x: _section_sort_key(x, rank_map))
    completed_thesis = [sec["content"] for sec in completed_thesis]
    completed_thesis = "\n\n".join(completed_thesis)
    completed_thesis = _sanitize_markdown_sse_artifacts(completed_thesis)
    with open(output_path, "w", encoding="utf-8") as f:
        f.write(completed_thesis)


def save_versioned_snapshot(state: "PaperWriterState", output_path: str, tag: str) -> str:
    save_markdown_snapshot(state, output_path)
    snapshots_dir = os.path.join("completed_history", "snapshots")
    os.makedirs(snapshots_dir, exist_ok=True)

    filename = os.path.basename(output_path)
    stem, ext = os.path.splitext(filename)
    safe_tag = re.sub(r"[^A-Za-z0-9_\-]+", "_", str(tag or "snapshot")).strip("_") or "snapshot"
    snapshot_path = os.path.join(snapshots_dir, f"{stem}__{safe_tag}{ext}")

    with open(output_path, "r", encoding="utf-8") as src:
        content = src.read()
    with open(snapshot_path, "w", encoding="utf-8") as dst:
        dst.write(content)

    return snapshot_path


def save_state_checkpoint(state: "PaperWriterState", checkpoint_path: str) -> None:
    checkpoint_dir = os.path.dirname(checkpoint_path)
    if checkpoint_dir:
        os.makedirs(checkpoint_dir, exist_ok=True)
    with open(checkpoint_path, "w", encoding="utf-8") as f:
        json.dump(state.export_checkpoint(), f, ensure_ascii=False, indent=2)


def load_state_checkpoint(checkpoint_path: str) -> Dict[str, Any]:
    return json.load(open(checkpoint_path, "r", encoding="utf-8-sig"))


def cat_input_from_md(inputs: Dict[str, Any], folder_path: str = "inputs") -> Dict[str, Any]:
    for md_file in os.listdir(folder_path):
        if not md_file.endswith(".md"):
            continue
        # research_gaps 统一由工作流节点自动生成，避免人工输入耦合。
        if md_file.lower() == "research_gaps.md":
            continue
        with open(os.path.join(folder_path, md_file), 'r', encoding='utf-8') as file:
            content = file.read()
            file_property = md_file[:-3]
            inputs[file_property] = content
    return inputs


def load_writing_guidance_library(folder_path: str = "inputs/guidance") -> Dict[str, str]:
    """
    从 guidance 目录加载模块写作指导文件。
    约定命名：*_guidance.md（例如 abstract_guidance.md, methods_guidance.md）。
    返回：{guidance_key: guidance_content}
    """
    guidance_map: Dict[str, str] = {}
    if not os.path.isdir(folder_path):
        return guidance_map

    for md_file in os.listdir(folder_path):
        if not md_file.endswith(".md"):
            continue
        if not md_file.endswith("_guidance.md"):
            continue
        file_path = os.path.join(folder_path, md_file)
        with open(file_path, "r", encoding="utf-8") as file:
            guidance_key = md_file[:-3]  # keep .md removed, e.g. abstract_guidance
            guidance_map[guidance_key] = file.read()
    return guidance_map


def load_review_guidance_library(folder_path: str = "inputs/review") -> Dict[str, str]:
    """
    从 review 目录加载模块化审稿规则文件。
    约定命名：*_review.md（例如 methods_review.md）。
    返回：{review_key: review_content}
    """
    review_map: Dict[str, str] = {}
    if not os.path.isdir(folder_path):
        return review_map

    for md_file in os.listdir(folder_path):
        if not md_file.endswith(".md"):
            continue
        if not md_file.endswith("_review.md"):
            continue
        file_path = os.path.join(folder_path, md_file)
        with open(file_path, "r", encoding="utf-8") as file:
            review_key = md_file[:-3]
            review_map[review_key] = file.read()
    return review_map


def serialize_guidance_catalog(guidance_map: Dict[str, str]) -> str:
    """
    将 guidance 库序列化为给 planner 的目录信息（文件名列表驱动）。
    """
    if not guidance_map:
        return "[]"
    catalog = []
    for key in sorted(guidance_map.keys()):
        catalog.append({
            "guidance_key": key,
            "source_file": f"{key}.md"
        })
    return json.dumps(catalog, ensure_ascii=False, indent=2)


def serialize_review_catalog(review_map: Dict[str, str]) -> str:
    """
    将 review 规则库序列化为 reviewer 可见的目录（文件名列表驱动）。
    """
    if not review_map:
        return "[]"
    catalog = []
    for key in sorted(review_map.keys()):
        catalog.append({
            "review_key": key,
            "source_file": f"{key}.md"
        })
    return json.dumps(catalog, ensure_ascii=False, indent=2)


class PaperWriterState:
    """
    论文生成状态管理器 (State Machine Context)
    用于在整个 Agentic Workflow 的各个节点之间传递、更新和保存上下文数据。
    """

    def __init__(self, inputs: Dict[str, Any], input_from_md: bool = True):
        # ==========================================
        # 1. 初始输入素材 (Initial Inputs)
        # ==========================================
        if input_from_md:
            inputs = cat_input_from_md(inputs)
        self.model: str = inputs.get("model", "gemini-3-pro")
        self.topic: str = str(inputs.get("topic", "")).strip()
        self.existing_sections: str = inputs.get("existing_sections", "无")
        self.existing_material: str = inputs.get("existing_material", "无")
        self.research_gaps: str = inputs.get("research_gaps", "")
        self.language: str = inputs.get("language", "English")
        self.user_requirements: str = inputs.get("user_requirements", "")
        self.related_works_path: str = inputs.get("related_works_path", "inputs/related_works.md")
        self.research_gap_output_path: str = inputs.get("research_gap_output_path", "outputs/research_gaps.md")
        self.paper_search_limit: int = int(inputs.get("paper_search_limit", 20))
        self.openalex_api_key: str = str(inputs.get("openalex_api_key", "")).strip()
        self.ark_api_key: str = str(inputs.get("ark_api_key", "")).strip()
        self.enable_auto_title = inputs.get("enable_auto_title", None)
        self.enable_paper_search = inputs.get("enable_paper_search", None)
        self.wait_for_manual_related_works: bool = bool(inputs.get("wait_for_manual_related_works", False))
        self.related_works_summary: str = inputs.get("related_works_summary", "")
        self.search_queries = inputs.get("search_queries", [])
        self.manual_revision_path: str = str(inputs.get("manual_revision_path", "inputs/revision_requests.md")).strip()
        self.manual_revision_notes: str = inputs.get("manual_revision_notes", "")
        self.pending_action: str = str(inputs.get("pending_action", "")).strip()
        self.pending_action_message: str = str(inputs.get("pending_action_message", "")).strip()
        os.makedirs(os.path.dirname(self.research_gap_output_path), exist_ok=True)
        if "writing_guidance_library" in inputs:
            self.writing_guidance_library = inputs.get("writing_guidance_library", {})
        else:
            guidance_dir = inputs.get("guidance_dir", "inputs/guidance")
            self.writing_guidance_library = load_writing_guidance_library(guidance_dir)

        if "review_guidance_library" in inputs:
            self.review_guidance_library = inputs.get("review_guidance_library", {})
        else:
            review_dir = inputs.get("review_dir", "inputs/review")
            self.review_guidance_library = load_review_guidance_library(review_dir)

        # 必备文件校验：overall_guidance.md 与 overall_review.md
        if "overall_guidance" not in self.writing_guidance_library:
            raise FileNotFoundError("Required guidance file missing: inputs/guidance/overall_guidance.md")
        if "overall_review" not in self.review_guidance_library:
            raise FileNotFoundError("Required review file missing: inputs/review/overall_review.md")

        if not self.related_works_summary:
            self.related_works_summary = read_text_if_exists(self.related_works_path)

        # ==========================================
        # 2. 全局架构数据 (Generated by Node 1: Architect)
        # ==========================================
        self.domain: str = ""  # 识别出的确切研究领域
        self.outline = inputs.get("outline", "")  # 完整论文大纲 (IMRaD结构)
        self.gaps_and_contributions: str = inputs.get("gaps_and_contributions", "")  # 文献空白与本研究贡献的严密映射

        # ==========================================
        # 3. 循环控制与过程状态 (Loop & Process State)
        # ==========================================
        # 存储已完成/审核通过的章节
        self.completed_sections = inputs.get("completed_sections", [])
        # 审稿循环状态
        self.passed: bool = bool(inputs.get("passed", False))
        self.reviewed_sections = inputs.get("reviewed_sections", [])
        self.review_summary: str = inputs.get("review_summary", "")
        self.major_review_plans = inputs.get("major_review_plans", [])
        self.review_round: int = int(inputs.get("review_round", 0))
        self.max_review_rounds: int = int(inputs.get("max_review_rounds", 3))
        # 工作流阶段控制：pre_research -> drafting -> review_pending -> reviewing -> done
        self.workflow_phase: str = inputs.get("workflow_phase", "pre_research")
        # 断点增强字段：用于更准确地恢复到具体执行位置
        self.current_major_chapter_id: str = str(inputs.get("current_major_chapter_id", "")).strip()
        self.current_sub_chapter_id: str = str(inputs.get("current_sub_chapter_id", "")).strip()
        self.current_node: str = str(inputs.get("current_node", "")).strip()
        self.last_checkpoint_reason: str = str(inputs.get("last_checkpoint_reason", "")).strip()
        self.last_checkpoint_time: str = str(inputs.get("last_checkpoint_time", "")).strip()
        self.resume_count: int = int(inputs.get("resume_count", 0))
    # ==========================================
    # 辅助方法 (Helper Methods)
    # ==========================================
    def get_sections_keys(self) -> str:
        """
        获取已完成章节的名称列表 (例如: "1. Introduction, 2. Methods")
        用于在 Prompt 中告诉模型目前写了哪些章节。
        """
        if not self.sections:
            return "目前暂无已完成的章节。"
        return ", ".join(list(self.sections.keys()))

    def get_sections_text(self) -> str:
        """
        获取所有已完成章节的合并文本，作为撰写下一节的上下文依据。
        """
        if not self.sections:
            return "无前文参考。"

        text_blocks = []
        for title, content in self.sections.items():
            text_blocks.append(f"## {title}\n{content}")
        return "\n\n".join(text_blocks)

    def save_current_section(self):
        """
        核心动作：当当前章节在 Node 5 (Judge) 被判定为 'done' 时，
        调用此方法将其归档到 sections 字典中，并清理当前草稿。
        """
        section_name = self.current_plan.get("section_to_write")
        if section_name and self.current_section_content:
            self.sections[section_name] = self.current_section_content
            print(f"📁 章节 [{section_name}] 审核通过，已成功归档至状态池。")

            # 清空当前草稿与计划，为规划下一节做准备
            self.current_section_content = ""
            self.current_plan = {}

    def mark_progress(
        self,
        node: str = "",
        reason: str = "",
        major_id: str = "",
        sub_id: str = "",
    ) -> None:
        """
        标记当前执行位置，供 checkpoint 记录和恢复时展示。
        """
        self.current_node = str(node or self.current_node).strip()
        self.last_checkpoint_reason = str(reason or self.last_checkpoint_reason).strip()
        self.current_major_chapter_id = str(major_id if major_id is not None else self.current_major_chapter_id).strip()
        self.current_sub_chapter_id = str(sub_id if sub_id is not None else self.current_sub_chapter_id).strip()
        self.last_checkpoint_time = datetime.now().strftime("%Y-%m-%d %H:%M:%S")

    def export_checkpoint(self) -> Dict[str, Any]:
        """
        将当前状态导出为字典（可配合 json.dump 保存为本地 checkpoint 文件），
        极其适合长耗时任务的断点续传机制。
        """
        return self.__dict__

    def get_prompt_language(self) -> str:
        """
        根据当前语言设置，返回提示词的语言版本
        返回 'zh' 表示中文提示词，'en' 表示英文提示词
        """
        return 'zh' if self.language.strip() == '中文' else 'en'

    def get_overall_guidance(self) -> str:
        return self.writing_guidance_library.get("overall_guidance", "")

    def get_overall_review(self) -> str:
        return self.review_guidance_library.get("overall_review", "")
