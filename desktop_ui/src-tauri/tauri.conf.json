{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ThesisLoom Desktop",
  "version": "0.2.0",
  "identifier": "com.thesisloom.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ThesisLoom Desktop",
        "width": 1600,
        "height": 980,
        "minWidth": 1080,
        "minHeight": 720,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "bin/ThesisLoomBackend"
    ],
    "icon": [
      "icons/icon.ico"
    ]
  }
}
